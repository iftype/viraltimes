HOST=127.0.0.1
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_VERSION=development
PUBLIC_WEB_ORIGIN=https://viralorigin.vercel.app
ADMIN_ORIGIN=http://localhost:3100
ADMIN_COOKIE_PATH=/viral
ADMIN_DATA_FILE=./.data/admin-inbox.json
MEME_DATA_FILE=./.data/memes.json
CATEGORY_DATA_FILE=./.data/categories.json
PARTICIPATION_DATA_FILE=./.data/participation.json
TREND_DATA_FILE=./.data/trend-snapshots.json
MEME_PULSE_FILE=./.data/meme-pulse.json
QUIZ_DB_FILE=./.data/quiz.sqlite
# 기존 JSON 퀴즈 카드/로그를 SQLite로 최초 1회 가져올 때만 사용합니다.
QUIZ_LOG_FILE=./.data/quiz-logs.json
# GitHub Actions 또는 서버 cron이 일별 스냅샷을 배치 전송할 때만 사용합니다.
TREND_INGEST_TOKEN=
# 관리자 링크 자동완성. Gemma는 설명 초안만 만들고 썸네일은 oEmbed/OG에서 추출합니다.
GEMMA_API_KEY=
GEMMA_MODEL=gemma-4-26b-a4b-it
# 기본 허용 목록 외 사이트를 쉼표로 추가합니다. 예: example.com,community.example
METADATA_ALLOWED_HOSTS=
# scrypt$<salt>$<hex digest>; 실제 값은 서버 환경 파일에만 저장합니다.
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
