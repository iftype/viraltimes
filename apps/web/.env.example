# Keep this relative in production so the public client never needs the server IP.
NEXT_PUBLIC_API_BASE_URL=/api
# Next.js 개발 서버의 상대 `/api` 프록시 대상입니다. 브라우저 번들에는 포함되지 않습니다.
DEV_API_ORIGIN=http://127.0.0.1:4000
# Microsoft Clarity 프로젝트를 만들고 Consent Mode를 켠 뒤 Project ID만 넣습니다.
# 비워두면 동의 배너와 Clarity 스크립트가 모두 렌더링되지 않습니다.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
